*.tif
*.tiff
*.npz
*.geojson
*.shp
*.dbf
*.shx
*.prj
*.qpj

# Large Image outputs and qualitative panels
*.png
*.jpg
*.jpeg
*.pdf
Individual_Comparison_Panels/
Qualitative_Panels/

# OS and IDE files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Temporary scratch and logs
scratch/
*.log
